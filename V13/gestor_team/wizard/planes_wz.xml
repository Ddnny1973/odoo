<?xml version="1.0" ?>
<odoo>
    <record id="gestor_actualizar_planes_wizard" model="ir.ui.view">
        <field name="name">gestor.actualizar.planes.wizard</field>
        <field name="model">gestor.actualizar.planes.wizard</field>
        <field name="arch" type="xml">
            <form string="Actualizar Planes TEAMS">
                <label
                    string="Este proceso actualizará los planes, tipos des planes y equipos desde la plataforma TIPS y STOK."
                    colspan="2"
                    for=""
                />
                <footer>
                    <button
                        name="actualizar_planes"
                        string="Ok"
                        type="object"
                        class="oe_highlight"
                    />
                    or
                    <button string="Cancel" class="oe_link" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_actualizar_planes_wizard" model="ir.actions.act_window">
        <field name="name">Actualizar planes, tipos de planes y equipos desde la plataforma TIPS y STOK</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">gestor.actualizar.planes.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
