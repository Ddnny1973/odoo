<?xml version="1.0" ?>
<odoo>
    <record id="gestor_liquidar_descuentos_wizard" model="ir.ui.view">
        <field name="name">gestor.liquidar.descuentos.wizard</field>
        <field name="model">gestor.liquidar.descuentos.wizard</field>
        <field name="arch" type="xml">
            <form string="Liquidación de Descuentos">
                <label
                    string="Este proceso liquida los descuentos generales."
                    colspan="2"
                    for=""
                />
                <group>
                    <field name="fecha_inicio"/>
                    <field name="fecha_fin"/>
                    <field name="sw_comision_ventas" invisible="True"/>
                    <field name="sw_comision_responsable"/>
                    <field name="sw_comision_incentivo"/>
                </group>
                <group>
                    <field name="empleados_ids" widget="many2many_tags" options="{'no_create_edit': True}" domain="['|', ('active','=', True), ('active','=', False)]"/>
                </group>
                <footer>
                    <button
                        name="action_liquidar_descuentos"
                        string="Ok"
                        type="object"
                        class="oe_highlight"
                    />
                    or
                    <button string="Cancel" class="oe_link" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_liquidar_descuentos" model="ir.actions.act_window">
        <field name="name">Liquidar Descuentos</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">gestor.liquidar.descuentos.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
