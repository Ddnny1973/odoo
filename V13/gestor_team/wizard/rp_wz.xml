<?xml version="1.0" ?>
<odoo>
    <record id="gestor_cruce_rp_wizard" model="ir.ui.view">
        <field name="name">gestor.cruce.rp.wizard</field>
        <field name="model">gestor.cruce.rp.wizard</field>
        <field name="arch" type="xml">
            <form string="Cruce de RP con TIPS">
                <label
                    string="Este proceso realizará el cruce del RP con TIPS."
                    colspan="2"
                    for=""
                />
                <group>
                    <field name="fecha_inicio"/>
                    <field name="fecha_fin"/>
                    <field name="fecha_inicio_rp"/>
                </group>
                <footer>
                    <button
                        name="cruzar_rp"
                        string="Ok"
                        type="object"
                        class="oe_highlight"
                    />
                    or
                    <button string="Cancel" class="oe_link" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
    <record id="action_cruce_rp_wizard" model="ir.actions.act_window">
        <field name="name">Cruzar RP con información de TIPS</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">gestor.cruce.rp.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
