<odoo>

    <!-- Captura Pyme -->
    <!-- Forms -->
    <record id="captura_pyme_form_view" model="ir.ui.view">
       <field name="name">gestor.captura.pyme.team.form.view</field>
       <field name="model">gestor.captura.pyme.team</field>
       <field name="arch" type="xml">
         <form string="Captura Pyme TEAM">
            <h1><font color="blue">PYME</font></h1>
            <group col="2">
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="id_cliente"/>
                        <field colspan="4" name="nombre_cliente"/>
                        <field colspan="4" name="tel_cliente"/>
                        <!-- <field colspan="4" name="id_asesor" groups="gestor_team.group_gestor_team"/> -->
                        <!-- <field colspan="4" name="nombre_asesor" groups="gestor_team.group_gestor_team"/> -->
                        <!-- <field colspan="4" name="id_responsable" readonly="True" groups="gestor_team.group_gestor_team"/> -->
                    </group>
                </div>
            </group>
            <group col="2">
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="cuenta"/>
                        <field colspan="4" name="ot"/>
                    </group>
                </div>
            </group>
            <group col="2">
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="valor" groups="gestor_team.group_gestor_team"/>
                    </group>
                    <group col="4">
                        <!-- <field colspan="4" name="create_uid" groups="gestor_team.group_gestor_team"/> -->
                        <field colspan="4" name="vendedor" groups="gestor_team.group_gestor_team" options="{'no_create_edit': True}"/>
                        <field colspan="4" name="identificacion_vendedor" groups="gestor_team.group_gestor_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="categoria_vendedor" groups="gestor_team.group_gestor_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="departamento_vendedor" groups="gestor_team.group_gestor_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="cargo_vendedor" groups="gestor_team.group_gestor_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="sucursal_vendedor" groups="gestor_team.group_gestor_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="id_responsable" groups="gestor_team.group_gestor_team" readonly="1" force_save="1"/>
                        <!-- <field colspan="4" name="create_uid" groups="gestor_team.group_gestor_team" /> -->
                        <!-- <field colspan="4" name="digitador" groups="gestor_team.group_gestor_team" readonly="1"/> -->
                        <field colspan="4" name="create_date" readonly="1" string="Fecha de creación"/>
                    </group>
                    <group col="4">
                        <field colspan="4" name="estado_venta" groups="gestor_team.group_gestor_team"/>
                        <field colspan="4" name="estado_contrato" groups="gestor_team.group_gestor_team"/>
                    </group>
                </div>
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="detalle_agrupado_captura_pyme_ids" />
                    </group>
                </div>
            </group>

            <group col="2">
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="referido"/>
                        <field colspan="4" name="cedula_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)]}"/>
                        <field colspan="4" name="nombre_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)]}"/>
                        <field colspan="4" name="telefono_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)]}"/>
                        <field colspan="4" name="correo_referido" attrs="{'invisible': [('referido','!=', True)]}"/>
                        <field colspan="4" name="banco_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)]}"/>
                        <field colspan="4" name="tipo_cuenta_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)]}"/>
                        <field colspan="4" name="cuenta_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)]}"/>

                    </group>
                </div>
                <div class="oe_title">
                    <field colspan="4" name="detalle_captura_pyme_ids" />
                </div>
            </group>

            <div class="oe_chatter">
                <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                <field name="message_ids" widget="mail_thread"/>
            </div>

         </form>
       </field>
    </record>

    <!-- tree -->
    <record id="captura_pyme_tree_view" model="ir.ui.view">
        <field name="name">gestor.captura.pyme.team.tree</field>
        <field name="model">gestor.captura.pyme.team</field>
        <field name="arch" type="xml">
            <tree>
                <field name="cuenta"/>
                <field name="ot"/>
                <field name="id_cliente"/>
                <field name="nombre_cliente"/>
                <field name="tel_cliente" optional="hide"/>
                <field name="valor" groups="gestor_team.group_gestor_team"/>
                <field name="red"/>
                <field name="servicio"/>
                <field name="estado_venta"/>
                <field name="estado_contrato"/>
                <field name="fecha"/>
                <field name="vendedor" />
                <field name="identificacion_vendedor" groups="gestor_team.group_gestor_team" readonly="1" optional="hide"/>
                <field name="categoria_vendedor" groups="gestor_team.group_gestor_team" readonly="1" optional="hide"/>
                <field name="departamento_vendedor" groups="gestor_team.group_gestor_team" readonly="1" optional="hide"/>
                <field name="cargo_vendedor" groups="gestor_team.group_gestor_team" readonly="1" optional="hide"/>
                <field name="sucursal_vendedor" groups="gestor_team.group_gestor_team" readonly="1" optional="hide"/>
                <field name="id_responsable" groups="gestor_team.group_gestor_team" readonly="1" optional="hide"/>
                <field name="referido" />
                <field name="nombre_referido" optional="hide" />
                <field name="cedula_referido" optional="hide" />
                <field name="telefono_referido" optional="hide" />
                <field name="correo_referido" optional="hide" />
                <field name="banco_referido" optional="hide" />
                <field name="tipo_cuenta_referido" optional="hide" />
                <field name="cuenta_referido" optional="hide" />
                <field name="digitador" optional="hide"/>
                <field name="create_date"  optional="hide" />
                <field name="create_uid" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- tree detalle -->
    <record id="captura_pyme_detalle_tree_view" model="ir.ui.view">
        <field name="name">gestor.captura.pyme.detalle.team.tree</field>
        <field name="model">gestor.captura.pyme.detalle.team</field>
        <field name="arch" type="xml">
            <tree>
                <field name="paquete"/>
                <field name="tipored"/>
                <field name="tipo_plan_id"/>
                <field name="division"/>
                <field name="renta" optional="show" groups="gestor_team.group_gestor_team"/>
                <field name="fecha" optional="hide" groups="gestor_team.group_gestor_team"/>
                <field name="venta" optional="hide" groups="gestor_team.group_gestor_team"/>
                <field name="paquete_pg" optional="hide" groups="gestor_team.group_gestor_team"/>
                <field name="paquete_pvd" optional="hide" groups="gestor_team.group_gestor_team"/>
                <field name="mintic" optional="hide"/>
                <field name="tipo_de_producto" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- tree detalle -->
    <record id="captura_pyme_detalle_agrupado_tree_view" model="ir.ui.view">
        <field name="name">gestor.captura.pyme.detalle.agrupado.team.tree</field>
        <field name="model">gestor.captura.pyme.detalle.agrupado.team</field>
        <field name="arch" type="xml">
            <tree>
                <field name="tipo_plan" />
                <field name="renta_total" widget='monetary'/>
            </tree>
        </field>
    </record>

    <!-- Filtros -->
    <record id="gestor_captura_pyme_filter_view" model="ir.ui.view">
        <field name="name">GESTOR CAPTURA PYME Filtros</field>
        <field name="model">gestor.captura.pyme.team</field>
        <field name="arch" type="xml">
            <search>
                <field name="cuenta" string="Venta/OT" filter_domain="['|', ('cuenta','ilike',self), ('ot','ilike',self)]"/>
                <field name="ot" string="OT" context="{'ot': self}" filter_domain="[('ot','ilike',self)]"/>
                <separator/>
                <filter name="group_estado_venta" string="Estado Venta" context="{'group_by': 'estado_venta'}"/>
            </search>
        </field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_captura_menu_pyme_team">
        <field name="name">PYMES</field>
        <field name="res_model">gestor.captura.pyme.team</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_captura_pyme_team">
        <field name="name">Captura PYME</field>
        <field name="res_model">gestor.captura.pyme.team</field>
        <field name="view_mode">tree,form</field>
