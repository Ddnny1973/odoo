    <!-- Filtross -->
    <record id="rp_team_filter_view" model="ir.ui.view">
        <field name="name">RP TEAMS Filtros</field>
        <field name="model">gestor.rp.team</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="RP" filter_domain="['|', ('imei','ilike',self), ('min','ilike',self)]"/>
                <field name="imei" string="IMEI" context="{'imei': self}" filter_domain="[('imei','ilike',self)]"/>
                <field name="min" string="MIN" context="{'min': self}" filter_domain="[('min','ilike',self)]"/>
                <separator/>
                <filter name="group_producto" string="Producto" context="{'group_by': 'producto'}"/>
                <filter name="group_producto1" string="Producto RONY" context="{'group_by': 'producto1'}"/>
            </search>
        </field>
    </record>

