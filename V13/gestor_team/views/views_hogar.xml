<odoo>
    <!-- views -->

    <!-- Estados antes del pago -->
    <!-- Forms -->
    <record id="estado_ap_team_form_view" model="ir.ui.view">
       <field name="name">estado_ap.team.form.view</field>
       <field name="model">gestor.estados_ap.team</field>
       <field name="arch" type="xml">
         <form string="Estados Antes del Pago TEAM">
               <group col="4">
                   <field colspan="4" name="name"/>
               </group>
         </form>
       </field>
    </record>

    <!-- tree -->
    <record id="estado_ap_team_tree_view" model="ir.ui.view">
        <field name="name">estado_ap.team.tree</field>
        <field name="model">gestor.estados_ap.team</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_estado_ap_team">
        <field name="name">Estados AP TEAM</field>
        <field name="res_model">gestor.estados_ap.team</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Estados Posterior al pago -->
    <!-- Forms -->
    <record id="estado_pp_team_form_view" model="ir.ui.view">
       <field name="name">estado_pp.team.form.view</field>
       <field name="model">gestor.estados_pp.team</field>
       <field name="arch" type="xml">
         <form string="Estados Posterior al Pago TEAM">
               <group col="4">
                   <field colspan="4" name="name"/>
               </group>
         </form>
       </field>
    </record>

    <!-- tree -->
    <record id="estado_pp_team_tree_view" model="ir.ui.view">
        <field name="name">estado_pp.team.tree</field>
        <field name="model">gestor.estados_pp.team</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_estado_pp_team">
        <field name="name">Estados PP TEAM</field>
        <field name="res_model">gestor.estados_pp.team</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Gestor Hogar -->
    <!-- Forms -->
    <record id="gestor_hogar_team_form_view" model="ir.ui.view">
       <field name="name">gestor.hogar.team.form.view</field>
       <field name="model">gestor.hogar.team</field>
       <field name="arch" type="xml">
         <form string="Gestor Hogar TEAM" delete="false">
                <group col="4">
                    <field colspan="4" name="name"/>
                    <field colspan="4" name="cuenta"/>
                    <field colspan="4" name="ot"/>
                </group>
                <group col="4">
                    <field colspan="4" name="idasesor"/>
                    <field colspan="4" name="nombreasesor"/>
                    <field colspan="4" name="vendedor_id"/>
                </group>
                <group col="4">
                    <field colspan="4" name="paquete"/>
                    <field colspan="4" name="producto_id"/>
                    <field colspan="4" name="cantserv"/>
                    <field colspan="4" name="cant_servicios"/>
                    <field colspan="4" name="tipo_red"/>
                    <field colspan="4" name="cod_tarifa"/>
                </group>
                <group col="4">
                    <field colspan="4" name="fecha"/>
                    <field colspan="4" name="fecha_venta"/>
                </group>
                <group col="4">
                    <field name="estrato"/>
                    <field name="estrato_claro"/>
                </group>
                <group col="4">
                    <field colspan="4" name="venta"/>
                    <field colspan="4" name="tipo_venta"/>
                    <field colspan="4" name="tipo_registro"/>
                    <field colspan="4" name="estado_ap"/>
                    <field colspan="4" name="estado_pp"/>
                    <field colspan="4" name="venta_convergente"/>
                </group>
                <group col="4">
                    <field name="visor_movil"/>
                    <field name="val_identidad"/>
                    <field name="serial_captor"/>
                </group>
                <group col="4">
                    <field name="create_date"/>
                </group>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
         </form>
       </field>
    </record>

    <!-- tree -->
    <record id="gestor_hogar_team_tree_view" model="ir.ui.view">
        <field name="name">gestor.hogar.team.tree</field>
        <field name="model">gestor.hogar.team</field>
        <field name="arch" type="xml">
            <tree delete="false" >
                <field name="name"/>
                <field name="cuenta"/>
                <field name="ot"/>
                <field name="idasesor"/>
                <field name="nombreasesor"/>
                <field name="vendedor_id"/>
                <field name="paquete"/>
                <field name="renta"/>
                <field name="producto_id"/>
                <field name="cantserv"/>
                <field name="cant_servicios"/>
                <field name="tipo_red"/>
                <field name="cod_tarifa"/>
                <field name="fecha"/>
                <field name="fecha_venta"/>
                <field name="estrato"/>
                <field name="estrato_claro"/>
                <field name="venta"/>
                <field name="tipo_venta"/>
                <field name="tipo_registro"/>
                <field name="estado_ap"/>
                <field name="estado_pp"/>
                <field name="visor_movil"/>
                <field name="val_identidad"/>
                <field name="serial_captor"/>
                <field name="venta_convergente"/>
                <field name="canal2" optional="hide"/>
                <field name="tipo_de_producto" optional="hide"/>
                <field name="create_date" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Filtross -->
    <record id="gestor_hogar_filter_view" model="ir.ui.view">
        <field name="name">GESTOR HOGAR Filtros</field>
        <field name="model">gestor.hogar.team</field>
        <field name="arch" type="xml">
            <search>
                <field name="cuenta" string="Cuenta/OT" filter_domain="['|', ('cuenta','ilike',self), ('ot','ilike',self)]"/>
                <field name="ot" string="OT" context="{'ot': self}" filter_domain="[('ot','ilike',self)]"/>
                <separator/>
                <filter name="group_estado_venta" string="Estado Venta" context="{'group_by': 'estado_ap'}"/>
            </search>
        </field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_hogar_team">
        <field name="name">Hogar Claro</field>
        <field name="res_model">gestor.hogar.team</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Captura Hogar -->
    <!-- Forms -->
    <record id="captura_hogar_form_view" model="ir.ui.view">
       <field name="name">gestor.captura.hogar.team.form.view</field>
       <field name="model">gestor.captura.hogar.team</field>
       <field name="arch" type="xml">
         <form string="Captura Hogares TEAM" delete="false">
             <header>
                 <button name="recalcular_liquidacion_comisiones" string="Recalcular" type="object" class="oe_highlight o_expense_submit" groups="gestor_team.group_gestor_modificar_creador_team"/>
                 <!-- <button name="liquidacion_comisiones" string="Liquidar" type="object" class="oe_highlight o_expense_submit" groups="gestor_team.group_gestor_modificar_creador_team"/> -->
                 <button name="busqueda_esquema_comision" string="Esquema" type="object" class="oe_highlight o_expense_submit" groups="gestor_team.group_gestor_modificar_creador_team"/>
             </header>

             <h1><font color="red">HOGAR</font></h1>
             <group col="2">
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="id_cliente"/>
                        <field colspan="4" name="nombre_cliente"/>
                        <field colspan="4" name="tel_cliente"/>
                        <!-- <field colspan="4" name="idasesor" groups="gestor_team.group_gestor_modificar_creador_team"/> -->
                        <!-- <field colspan="4" name="cargo" groups="gestor_team.group_gestor_modificar_creador_team"/> -->
                        <!-- <field colspan="4" name="nombreasesor" groups="gestor_team.group_gestor_modificar_creador_team"/> -->
                        <!-- <field colspan="4" name="id_responsable" readonly="True" groups="gestor_team.group_gestor_modificar_creador_team"/> -->
                    </group>
                </div>
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="fecha" readonly="1" force_save="True"/>
                    </group>
                    <group col="4">
                        <field colspan="4" name="cuenta" attrs="{'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                        <field colspan="4" name="ot" attrs="{'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                        <field colspan="4" name="paquete_global" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <!--<field colspan="4" name="paquete_pvd" groups="gestor_team.group_gestor_modificar_creador_team"/>-->
                        <field colspan="4" name="tipo_registro" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="venta_convergente" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="mintic" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                    </group>
                    <group>
                        <field colspan="4" name="log_estados" attrs="{'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                    </group>
                </div>
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="referido" attrs="{'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                        <field colspan="4" name="tipo_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)], 'readonly': [('comision_pagada','=', True)]}"/>
                        <field colspan="4" name="cedula_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)], 'readonly': [('comision_pagada','=', True)]}"/>
                        <field colspan="4" name="nombre_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)], 'readonly': [('referido_existente', '=', True)], 'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                        <field colspan="4" name="telefono_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)], 'readonly': [('referido_existente', '=', True)], 'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                        <field colspan="4" name="correo_referido" attrs="{'invisible': [('referido','!=', True)], 'readonly': [('referido_existente', '=', True)]}" force_save="True"/>
                        <field colspan="4" name="banco_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)], 'readonly': [('referido_existente', '=', True)], 'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                        <field colspan="4" name="tipo_cuenta_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)], 'readonly': [('referido_existente', '=', True)], 'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                        <field colspan="4" name="cuenta_referido" attrs="{'invisible': [('referido','!=', True)], 'required': [('referido','=', True)], 'readonly': [('referido_existente', '=', True)], 'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                        <field colspan="4" name="referido_existente" invisible="1"/>

                    </group>
                </div>
            </group>
            <group col="2">
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="cantserv" readonly="1" force_save="True"/>
                        <!--<field colspan="4" name="tipored" groups="gestor_team.group_gestor_modificar_creador_team"/>-->
                        <!--<field colspan="4" name="division" groups="gestor_team.group_gestor_modificar_creador_team"/>-->
                        <field colspan="4" name="area" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="zona" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="d_distrito" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="poblacion" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                    </group>
                </div>
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="tercero" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="punto" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="grupo" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="categoria" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="canal2" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="tipo_de_producto" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                    </group>
                </div>
            </group>
            <div class="oe_title">
                <!-- <group>
                    <field colspan="4" name="comision_liquidada" groups="gestor_team.group_gestor_modificar_creador_team"/>
                    <field colspan="4" name="fecha_liquidacion_comision" groups="gestor_team.group_gestor_modificar_creador_team"/>
                    <field colspan="4" name="usuario_liquidador" groups="gestor_team.group_gestor_modificar_creador_team"/>
                </group> -->
                <group>
                    <field colspan="4" name="comision_pagada" groups="gestor_team.group_gestor_modificar_creador_team" invisible="1"/>
                    <!-- <field colspan="4" name="fecha_pago_comision" groups="gestor_team.group_gestor_modificar_creador_team"/>
                    <field colspan="4" name="usuario_pagador" groups="gestor_team.group_gestor_modificar_creador_team"/> -->
                </group>
            </div>
            <group col="2">
                <div class="oe_title">
                    <group col="4">
                        <!--<field colspan="4" name="renta" groups="gestor_team.group_gestor_modificar_creador_team"/>-->
                        <field colspan="4" name="renta_global" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="valor_comision" readonly="1" force_save="True"/>

                        <field colspan="4" name="no_contrato" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="estrato" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <!--<field colspan="4" name="paquete_pg" groups="gestor_team.group_gestor_modificar_creador_team"/>-->
                        <!--<field colspan="4" name="mintic" groups="gestor_team.group_gestor_modificar_creador_team"/>-->
                        <!--<field colspan="4" name="tipo_de_producto" groups="gestor_team.group_gestor_modificar_creador_team"/>-->
                        <field colspan="4" name="gv_area" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="cod_tarifa" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="visor_movil" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="val_identidad" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="serial_captor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="True"/>
                        <field colspan="4" name="estado_venta" groups="gestor_team.group_gestor_modificar_creador_team" attrs="{'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                        <field colspan="4" name="estado_posterior_al_pago_claro" string="Est. Post. Pago" groups="gestor_team.group_gestor_modificar_creador_team"/>
                        <field colspan="4" name="vendedor" groups="gestor_team.group_gestor_modificar_creador_team" options="{'no_create_edit': True}" attrs="{'readonly': [('comision_pagada','=', True)]}" force_save="True"/>
                        <field colspan="4" name="identificacion_vendedor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="categoria_vendedor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="departamento_vendedor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="cargo_vendedor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="sucursal_vendedor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="id_responsable" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="especial_hogar" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="tarifa_especial_id" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="1"/>
                        <field colspan="4" name="contar_servicios" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" force_save="1"/>
                        <!-- <field colspan="4" name="create_uid" groups="gestor_team.group_gestor_modificar_creador_team" /> -->
                        <!-- <fild colspan="4" name="digitador" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1"/> -->
                        <field colspan="4" name="create_date" readonly="1" string="Fecha de creación"/>
                    </group>
                </div>
                <div class="oe_title">
                    <group col="4">
                        <field colspan="4" name="detalle_agrupado_captura_hogar_ids" groups="gestor_team.group_gestor_modificar_creador_team"  readonly="1"/>
                    </group>
                </div>
            </group>

            <group>
                <field colspan="4" name="detalle_captura_hogar_ids" groups="gestor_team.group_gestor_modificar_creador_team"  readonly="1"/>
            </group>

            <div class="oe_chatter">
                <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                <field name="message_ids" widget="mail_thread"/>
            </div>
         </form>
       </field>
    </record>

    <!-- tree -->
    <record id="captura_hogar_tree_view" model="ir.ui.view">
        <field name="name">gestor.captura.hogar.team.tree</field>
        <field name="model">gestor.captura.hogar.team</field>
        <field name="arch" type="xml">
            <tree delete="false" decoration-danger ="estado_venta not in (1,2)">
                <field name="cuenta"/>
                <field name="ot"/>
                <field name="id_cliente"/>
                <field name="nombre_cliente"/>
                <field name="tel_cliente"/>
                <field name="paquete_global"/>
                <field name="estado_venta"/>
                <field name="fecha"/>
                <field name="idasesor" optional='hide' groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="cargo" optional='hide' groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="nombreasesor" optional='hide' groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="cantserv" optional="show" />
                <field name="area" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="zona" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="poblacion" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="d_distrito" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="tercero" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="punto" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="renta_global" optional="show" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="grupo" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="categoria" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="tipo_registro" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="canal2" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="tipo_de_producto" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="no_contrato" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="estrato" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="paquete_global" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="venta_convergente" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="mintic" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="gv_area" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="cod_tarifa" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="venta_convergente" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="visor_movil" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="val_identidad" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="serial_captor" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="estado_venta" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="estado_posterior_al_pago_claro" optional="hide" groups="gestor_team.group_gestor_modificar_creador_team"/>
                <field name="vendedor"/>
                <!-- <field name="digitador" optional="hide"/> -->
                <field name="create_date"  optional="hide" />
                <!-- <field name="create_uid" optional="hide"/> -->
                <field name="identificacion_vendedor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" optional="hide"/>
                <field name="categoria_vendedor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" optional="hide"/>
                <field name="departamento_vendedor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" optional="hide"/>
                <field name="cargo_vendedor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" optional="hide"/>
                <field name="sucursal_vendedor" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" optional="hide"/>
                <field name="tarifa_especial_id" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" optional="hide"/>
                <field name="id_responsable" groups="gestor_team.group_gestor_modificar_creador_team" readonly="1" optional="hide"/>
                <field name="valor_comision" readonly="1" />
