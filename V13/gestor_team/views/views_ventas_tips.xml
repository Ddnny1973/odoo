    <!-- Filtross -->
    <record id="ventas_team_filter_view" model="ir.ui.view">
        <field name="name">Ventas TEAMS Filtros</field>
        <field name="model">gestor.consulta.ventas.tips</field>
        <field name="arch" type="xml">
            <search>
                <field name="imei" string="Ventas" filter_domain="['|', ('imei','ilike',self), ('min','ilike',self)]"/>
                <field name="imei" string="IMEI" context="{'imei': self}" filter_domain="[('imei','ilike',self)]"/>
                <field name="min" string="MIN" context="{'min': self}" filter_domain="[('min','ilike',self)]"/>
                <separator/>
                <filter name="nombre_del_plan" string="Nombre del plan" context="{'group_by': 'nombre_del_plan'}"/>
            </search>
        </field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_ventas_tips">
        <field name="name">Ventas TIPS</field>
        <field name="res_model">gestor.consulta.ventas.tips</field>
        <field name="view_mode">tree,form</field>
    </record>



</odoo>
