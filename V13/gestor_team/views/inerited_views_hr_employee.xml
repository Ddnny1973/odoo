<odoo>
    <record id="gestor_hr_employee_tree_view" model="ir.ui.view">
        <field name="name">gestor.hr.employee.tree.view</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='identification_id']" position="after">
                <field name="sucursal_id"/>
                <field name="category_id"/>
                <field name="tarifa_especial_id"/>
                <field name="tipo_cuenta" optional="hide"/>
                <field name="banco_id" optional="hide"/>
                <field name="cuenta_id" optional="hide"/>
                <field name="nombre_titular" optional="hide"/>
                <field name="tipo_documento_titular" optional="hide"/>
                <field name="identificacion_titular" optional="hide"/>
            </xpath>
        </field>
    </record>

