    <!-- Descuentos -->
    <record model="ir.ui.view" id="view_hr_employee_form_inherited">
        <field name="name">hr.employee.descuentos.form.inherited</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority" eval="90"/>
        <field name="arch" type="xml">
           <xpath expr="//page[@name='hr_settings']/group" position="after">
             <group string="Descuentos" name="descuentos">
                 <field name="prestamos" string=""/>
             </group>
          </xpath>
          <xpath expr="//page[@name='hr_settings']/group/group/field[@name='user_id']" position="after">
                <field name="user_id_tips" string="USER ID TIPSII"/>
         </xpath>
        </field>
    </record>
