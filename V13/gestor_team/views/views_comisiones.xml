<odoo>
    <!-- views -->

    <!-- Comisiones -->
    <!-- Forms -->
    <record id="comisiones_team_form_view" model="ir.ui.view">
       <field name="name">comisiones.team.form.view</field>
       <field name="model">gestor.comisiones.team</field>
       <field name="arch" type="xml">
         <form string="Esquemas de Comisiones TEAM">
            <widget name="web_ribbon" title="Descuento" bg_color="bg-danger" attrs="{'invisible': ['|', ('tipo_comision', 'in', ('incentivo', 'comision', 'biometria')), ('tipo_comision', '=', False)]}"/>
            <widget name="web_ribbon" title="Incentivo" bg_color="bg-dark" attrs="{'invisible': ['|', ('tipo_comision', 'in', ('descuento', 'comision', 'biometria')), ('tipo_comision', '=', False)]}"/>
            <widget name="web_ribbon" title="Biometrías" bg_color="bg-primary" attrs="{'invisible': ['|', ('tipo_comision', 'in', ('descuento', 'comision', 'incentivo')), ('tipo_comision', '=', False)]}"/>

            <group col="4">
                <field name="name"/>
                <field name="codigo"/>
                <field name="descripcion"/>
                <field name="active"/>
            </group>
            <group>
                <!-- <field name="es_incentivo"/> -->
                <field name="tipo_comision"/>
                <!-- <field name="estado_venta"
                    widget="many2many_tags"
                    attrs="{'invisible': [('tipo_comision', 'in', ('incentivo', 'comision', 'descuento'))],
                    'required': [('tipo_comision', 'in', ('biometria'))]}"
                    domain="[('name', 'in', ('Instalada', 'Digitada'))]"
                /> -->
                <!-- <field name="convergencia"/> -->
                </group>
            <separator string="Grupo Empleados" />
            <div label="Grupo Empleados">
                <group col="4">
                    <field colspan="4" name="por_responsable" attrs="{'readonly': ['|', ('referidos_ids', '!=', []), '|', ('employees_ids', '!=', []), '|', ('categoria_empleado_ids', '!=', []), '|', ('job_ids', '!=', []), '|', ('canales_ids', '!=', [])]}"/>
                    <field colspan="4" name="employees_ids" widget="many2many_tags" attrs="{'readonly': ['|', ('referidos_ids', '!=', []), '|', ('por_responsable', '!=', False), '|', ('categoria_empleado_ids', '!=', []), '|', ('job_ids', '!=', []), '|', ('canales_ids', '!=', [])]}" options="{'no_create_edit': True}"/>
                    <field colspan="4" name="categoria_empleado_ids" widget="many2many_tags" attrs="{'readonly': ['|', ('referidos_ids', '!=', []), '|', ('por_responsable', '!=', False), '|', ('employees_ids', '!=', []), '|', ('job_ids', '!=', []), '|', ('canales_ids', '!=', [])]}" options="{'no_create_edit': True}"/>
                    <field colspan="4" name="job_ids" widget="many2many_tags" attrs="{'readonly': ['|', ('referidos_ids', '!=', []), '|', ('por_responsable', '!=', False), '|', ('employees_ids', '!=', []), '|', ('categoria_empleado_ids', '!=', []), '|', ('canales_ids', '!=', [])]}" options="{'no_create_edit': True}"/>
                    <field colspan="4" name="canales_ids" widget="many2many_tags" attrs="{'readonly': ['|', ('referidos_ids', '!=', []), '|', ('por_responsable', '!=', False), '|', ('employees_ids', '!=', []), '|', ('categoria_empleado_ids', '!=', []), '|', ('job_ids', '!=', [])]}" options="{'no_create_edit': True}"/>
                </group>
                <group col="4">
                    <field colspan="4" name="referidos_ids" widget="many2many_tags" attrs="{'readonly': ['|', ('por_responsable', '!=', False),
                                                                                                         '|', ('categoria_empleado_ids', '!=', []),
                                                                                                         '|', ('job_ids', '!=', []),
                                                                                                         '|', ('canales_ids', '!=', []),
                                                                                                         '|', ('employees_ids', '!=', [])]}"
                                                                                                         options="{'no_create_edit': True}"/>
                </group>
            </div>
            <div>
               <group col="2">
                   <field colspan="2" name="all_referidos"/>
                    <!-- <field colspan="2" name="pago_obligado"/> -->
               </group>
            </div>
            <separator string="Condiciones (La posición en la lista indica prioridad)" />
            <group col="1">
              <field colspan="1" name="condiciones_ids" />
            </group>
            <!-- <separator string="Sucursales" />
            <div>
             <group col="2">
                 <field colspan="2" name="sucursales_ids" widget="many2many_tags"/>
             </group>
            </div> -->
             <!-- <separator string="Porcentajes de Pago" />
             <div>
                 <group col="4">
                     <field colspan="4" name="porc_pago"/>
                     <field colspan="4" name="pago_fijo"/>
                 </group>
             </div> -->
             <!-- <separator string="Tarifas Especiales" attrs="{'invisible': [('limite_ventas_count', '>', 0)]}"/>
             <div>
                 <field colspan="2" name="tarifas_especiales_count" invisible="True"/>
                 <group col="4">
                     <field colspan="4" name="tarifas_especiales_ids" widget="many2many_tags" attrs="{'invisible': [('limite_ventas_count', '>', 0)]}"/>
                 </group>
             </div> -->
             <!-- <separator string="Grupo Planes (mutamente excluyentes)" />
             <div>
                 <group col="4">
                     <field colspan="4" name="planes_ids" widget="many2many_tags" attrs="{'readonly': ['|', ('categoria_tipo_plan_ids', '!=', []), ('tipo_plan_ids', '!=', [])]}"/>
                     <field colspan="4" name="categoria_tipo_plan_ids" widget="many2many_tags" attrs="{'readonly': ['|', ('planes_ids', '!=', []), ('tipo_plan_ids', '!=', [])]}"/>
                     <field colspan="4" name="tipo_plan_ids" widget="many2many_tags" attrs="{'readonly': ['|', ('planes_ids', '!=', []), ('categoria_tipo_plan_ids', '!=', [])]}"/>
                 </group>
                 <group col="4">
                     <separator string="Exepciones de planes" />
                     <field colspan="4" name="planes_ex_ids" widget="many2many_tags"/>
                 </group>
             </div> -->
             <!-- <separator string="Servicios" />
             <div>
                 <group col="4">
                     <field colspan="4" name="servicios_tmp" />
                 </group>
             </div> -->
             <!-- <separator string="Topes" attrs="{'invisible': [('tarifas_especiales_count', '>', 0)]}"/>
             <div>
                 <field colspan="2" name="limite_ventas_count" invisible="True"/>
                 <group col="1">
                    <field colspan="1" name="limite_ventas" attrs="{'invisible': [('tarifas_especiales_count', '>', 0)]}"/>
                 </group>
             </div> -->

             <!-- <separator string="Valores a pagar" />
             <div>
               <group col="2">
                   <field colspan="2" name="tipo_pago"/>
                   <field colspan="2" name="mes1"/>
               </group>
             </div> -->

             <div>
                <group col="2">
                     <field colspan="2" name="secuencia" readonly="1"/>
                </group>
             </div>

             <div class="oe_chatter">
                  <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                  <field name="message_ids" widget="mail_thread"/>
             </div>
         </form>
       </field>
    </record>

    <!-- tree -->
    <record id="comisiones_team_tree_view" model="ir.ui.view">
        <field name="name">comisiones.team.tree</field>
        <field name="model">gestor.comisiones.team</field>
        <field name="arch" type="xml">
            <tree >
                <field name="name"/>
                <field name="codigo"/>
                <field name="tipo_comision"/>

                <!-- <field name="sucursales_ids" optional="hide"/> -->
                <!-- <field name="job_ids" optional="hide"/> -->
                <!-- <field name="canal_id" optional="hide"/> -->
                <!-- <field name="dependencia_id" optional="hide"/> -->
                <!-- <field name="tope_minimo" optional="hide"/> -->
                <!-- <field name="tope_maximo" optional="hide"/> -->
                <!-- <field name="meta" optional="hide"/> -->
                <!-- <field name="porc_pago" optional="hide"/> -->
                <!-- <field name="pago_fijo" optional="hide"/> -->
                <field colspan="2" name="secuencia" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- tree -->
    <record id="gestor_limites_venta_tree_view" model="ir.ui.view">
        <field name="name">gestor.limites.venta.tree</field>
        <field name="model">gestor.limites.venta</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="desde"/>
                <field name="hasta" />
                <field name="valor" />
            </tree>
        </field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_comisiones_team">
        <field name="name">Esquemas de Comisiones TEAM</field>
        <field name="res_model">gestor.comisiones.team</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- views Gestor Consulta Comisiones Ventas-->

    <!-- Forms -->

    <!-- tree -->
    <record id="gestor_consulta_comisiones_tips_tree_view" model="ir.ui.view">
        <field name="name">gestor.consulta.comisiones.tips.tree</field>
        <field name="model">gestor.consulta.comisiones.tips</field>
        <field name="arch" type="xml">
            <tree>
                <field name="fecha"/>
                <field name="min"/>
                <field name="iccid"/>
                <field name="imei"/>
                <field name="estado_tips" optional="hide"/>
                <field name="nombre_del_plan" string="Nombre del plan TIPS"/>
                <field name="plan_id"/>
                <field name="tipo_de_plan"/>
                <field name="contrato" optional="hide"/>
                <field name="valor" optional="hide"/>
                <field name="custcode" optional="hide"/>
                <field name="marca_del_equipo" optional="hide"/>
                <field name="nombre_de_equipo_en_stok" optional="hide"/>
                <field name="nombre_de_la_simcard_en_stok" optional="hide"/>
                <field name="modelo_del_equipo" optional="hide"/>
                <field name="valor_del_equipo" optional="hide"/>
                <field name="nombre_para_mostrar_del_vendedor" optional="hide"/>
                <field name="tipo_de_vendedor" optional="hide"/>
                <field name="regional" optional="hide"/>
                <field name="sucursal" optional="hide"/>
                <field name="ciudad" optional="hide"/>
                <field name="valor_cobrado" optional="hide"/>
                <field name="codigo_distribuidor" optional="hide"/>
                <field name="cliente_nombre" optional="hide"/>
                <field name="cliente_id" optional="hide"/>
                <field name="vendedor_nombre" optional="show"/>
                <field name="vendedor_id" optional="show"/>
                <field name="cargo_fijo_mensual" optional="hide"/>
                <field name="permanencia_pendiente" optional="hide"/>
                <field name="clasificacion_del_plan" optional="hide"/>
                <field name="es_multiplay" optional="hide"/>
                <field name="es_upgrade" optional="hide"/>
                <field name="es_linea_nueva" optional="hide"/>
                <field name="es_venta_digital" optional="hide"/>
                <field name="es_con_equipo" optional="hide"/>
                <field name="es_telemercadeo" optional="hide"/>
                <field name="fecha_de_activacion_en_punto_de_activacion" optional="hide"/>
                <field name="usuario_creador" optional="hide"/>
                <field name="venta_id" optional="hide"/>
                <field name="valor_a_pagar" optional="show"/>
                <field name="cargo" optional="show"/>
                <field name="categoria_empleado" optional="show"/>
                <field name="responsable_nombre" optional="show"/>
                <field name="tipo_plan" optional="show"/>
                <field name="categoria_tipo_plan" optional="show"/>
                <field name="mes" optional="show"/>
                <field name="year" optional="show"/>
                <field name="presupuesto" optional="show"/>
                <field name="empleado_id" optional="show"/>
                <field name="comision_pagada" optional="show"/>
                <field name="reconocimiento_pagado" optional="show"/>
                <field name="tipo_de_activacion" optional="show"/>
                <field name="con_equipo" optional="show"/>
                <field name="cfm" optional="show"/>
                <field name="cfm_con_iva" optional="show"/>
                <field name="cfm_sin_iva" optional="show"/>
                <field name="mes_de_liquidacion" optional="show"/>
                <field name="esquemas_ids" optional="show"/>

            </tree>
        </field>
    </record>

    <!-- Filtros -->
    <record id="gestor_consulta_comisiones_tips_filter_view" model="ir.ui.view">
        <field name="model">gestor.consulta.comisiones.tips</field>
        <field name="arch" type="xml">
            <search>
                <field name="imei" string="IMEI" filter_domain="[('imei','ilike',self)]"/>
                <field name="nombre_del_plan" string="Nombre del plan" filter_domain="[('nombre_del_plan','ilike',self)]"/>
                <separator/>
                <filter name="nombre_del_plan" string="Nombre del plan" context="{'group_by': 'nombre_del_plan'}"/>
            </search>
        </field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_consulta_comisiones_tips">
        <field name="name">Ventas Comisiones TIPS</field>
        <field name="res_model">gestor.consulta.comisiones.tips</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- tree Alto Valor-->
    <record id="alto_valor_team_tree_view" model="ir.ui.view">
        <field name="name">gestor.alto.valor.team.tree</field>
        <field name="model">gestor.alto.valor.team</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="valor_inferior"/>
                <field name="valor_superior"/>
            </tree>
        </field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_alto_valor_team">
        <field name="name">Alto Valor</field>
        <field name="res_model">gestor.alto.valor.team</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Repositorio comisiones-->
    <record id="gestor_repositorio_comisiones_team_tree_view" model="ir.ui.view">
        <field name="name">gestor.repositorio.comisiones.team.tree</field>
        <field name="model">gestor.repositorio.comisiones.team</field>
        <field name="arch" type="xml">
            <tree delete="false">
                <field name="captura_id"/>
                <field name="hogar_id"/>
                <field name="padre_id"/>
                <field name="vendedor"/>
                <field name="valor_comision"/>
                <field name="esquema_id"/>
                <field name="tipo_comision"/>
                <field name="tipo_pago" optional="hide"/>
                <field name="valor1" optional="hide"/>
                <field name="cuenta"/>
                <field name="ot"/>
                <field name="fecha_venta" optional="hide"/>
                <field name="fecha_pago_comision" optional="hide"/>
                <field name="biometrias_id" optional="hide"/>
                <field name="tarifa_especial_id" optional="hide"/>
                <field name="comision_pagada"/>
                <field name="fecha_pago_comision"/>
                <field name="id" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Filtros -->
    <record id="gestor_repositorio_comisiones_team_filter_view" model="ir.ui.view">
        <field name="model">gestor.repositorio.comisiones.team</field>
        <field name="arch" type="xml">
            <search>
                <field name="padre_id" string="Padre/OT/Cuenta" filter_domain="['|','|',('padre_id','ilike',self), ('ot', 'ilike', self), ('cuenta', 'ilike', self)]"/>
                <separator/>
                <filter name="comision_pagada" string="Comisión pagada" context="{'group_by': 'comision_pagada'}"/>
                <filter name="tipo_comision" string="Tipo comisión" context="{'group_by': 'tipo_comision'}"/>
            </search>
        </field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_repositorio_comisiones_team">
        <field name="name">Repositorio Comisiones</field>
        <field name="res_model">gestor.repositorio.comisiones.team</field>
        <field name="view_mode">tree</field>
    </record>

    <!-- tree Tipo Condiciones-->
    <record id="gestor_tipo_condiciones_comisiones_team_tree_view" model="ir.ui.view">
        <field name="name">gestor.tipo.condiciones.comisiones.team.tree</field>
        <field name="model">gestor.tipo.condiciones.comisiones.team</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- actions -->
    <record model="ir.actions.act_window" id="gestor_team.gestor_tipo_condiciones_comisiones_team">
        <field name="name">Tipo de Condiciones</field>
        <field name="res_model">gestor.tipo.condiciones.comisiones.team</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- tree Condiciones-->
    <record id="gestor_prioridades_comisiones_team_tree_view" model="ir.ui.view">
        <field name="name">gestor.prioridades.comisiones.team.tree</field>
        <field name="model">gestor.prioridades.comisiones.team</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="tarifas_especiales_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="convergencia"/>
                <!-- <field name="categoria_tipo_plan_ids" widget="many2many_tags"/> -->
                <field name="tipo_plan_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="planes_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="planes_ex_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="estado_venta" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="tipo_registro" widget="many2many_tags"/>
                <field name="distrito_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="employees_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="sucursal_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="job_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="tipo_referido"/>
                <field name="servicios"/>
                <field name="tipo_pago"/>
                <field name="valor_pago"/>
                <field name="fecha_inicio" optional='show' />
                <field name="fecha_fin" optional='show' />
                <field name="limite_ventas_ids" optional='hide' />
                <field name="tipo_biometria" optional='hide' />
            </tree>
        </field>
    </record>

    <record id="gestor_prioridades_comisiones_team_form_view" model="ir.ui.view">
        <field name="name">gestor.prioridades.comisiones.team.form.view</field>
        <field name="model">gestor.prioridades.comisiones.team</field>
        <field name="arch" type="xml">
            <form string="Condiciones de los Esquemas">
                <field name="sequence" invisible="True"/>
                <div>
                    <group col="2">
                        <field colspan="2" name="tarifas_especiales_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                        <field colspan="2" name="convergencia"/>
                    </group>
                </div>
                <div>
                    <group col="2">
                        <!-- <field colspan="2" name="categoria_tipo_plan_ids" widget="many2many_tags"/> -->
                        <field colspan="2" name="tipo_plan_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                        <field colspan="2" name="planes_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                        <field colspan="2" name="planes_ex_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                    </group>
                </div>
                <div>
                    <group col="2">
                        <field colspan="2" name="servicios"/>
                        <field colspan="2" name="tipo_pago"/>
                        <field colspan="2" name="valor_pago"/>
                    </group>
                </div>
                <div>
                    <group col="2">
                        <field colspan="4" name="employees_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                        <field colspan="4" name="sucursal_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                        <field colspan="4" name="job_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                    </group>
                </div>
                <div>
                    <group col="2">
                        <field name="estado_venta" widget="many2many_tags" options="{'no_create_edit': True}"/>
                        <field name="tipo_registro" widget="many2many_tags"/>
                        <field colspan="4" name="distrito_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                        <field colspan="2" name="tipo_referido"/>
                        <field colspan="2" name="tipo_biometria"/>
                        <field name="fecha_inicio" optional='show' />
                        <field name="fecha_fin" optional='show' />
                    </group>
                </div>
                <field colspan="2" name="tarifas_especiales_count" invisible="True"/>
                <!-- <separator string="Topes" attrs="{'invisible': [('tarifas_especiales_count', '>', 0)]}"/> -->
                <separator string="Topes" />
                <div>
                    <group col="1">
                       <!-- <field colspan="1" name="limite_ventas_ids" attrs="{'invisible': [('tarifas_especiales_count', '>', 0)]}"/> -->
                       <field colspan="1" name="limite_ventas_ids" />
                    </group>
                </div>

                <div class="oe_chatter">
                     <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                     <field name="message_ids" widget="mail_thread"/>
                </div>

            </form>
        </field>
    </record>


</odoo>
