<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sicone_informes_form" model="ir.ui.view">
        <field name="name">sicone.informes.form</field>
        <field name="model">sicone.informes</field>
        <field name="arch" type="xml">
            <form string="Informes Ejecutivos">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    
                    <notebook>
                        <page string="Multiproyecto" name="multiproyecto">
                            <group>
                                <field name="fecha_generacion_mp" readonly="1"/>
                            </group>
                            <group string="Reporte Histórico">
                                <div class="alert alert-info" role="alert">
                                    <p><b>Reporte Gerencial Multiproyecto</b></p>
                                    <p>Genera reporte con KPIs, Waterfall, gráficos y tabla de proyectos.</p>
                                </div>
                            </group>
                            <group>
                                <button name="action_generar_multiproyecto" 
                                        string="📄 Generar PDF Multiproyecto" 
                                        type="object" 
                                        class="btn btn-primary btn-lg"
                                        style="width: 100%;"/>
                            </group>
                            <group attrs="{'invisible': [('pdf_multiproyecto', '=', False)]}">
                                <button name="action_download_multiproyecto" 
                                        string="⬇️ Descargar PDF Multiproyecto" 
                                        type="object" 
                                        class="btn btn-success btn-lg"
                                        style="width: 100%;"/>
                            </group>
                        </page>
                        
                        <page string="Proyecciones e Inversiones" name="proyecciones">
                            <group>
                                <field name="fecha_generacion_proy" readonly="1"/>
                            </group>
                            <group string="Reporte Prospectivo">
                                <div class="alert alert-info" role="alert">
                                    <p><b>Proyecciones de Cash Flow e Inversiones</b></p>
                                    <p>Genera reporte con proyecciones, Gantt inversiones y tabla mensual.</p>
                                </div>
                            </group>
                            <group>
                                <button name="action_generar_proyecciones" 
                                        string="📊 Generar PDF Proyecciones" 
                                        type="object" 
                                        class="btn btn-primary btn-lg"
                                        style="width: 100%;"/>
                            </group>
                            <group attrs="{'invisible': [('pdf_proyecciones', '=', False)]}">
                                <button name="action_download_proyecciones" 
                                        string="⬇️ Descargar PDF Proyecciones" 
                                        type="object" 
                                        class="btn btn-success btn-lg"
                                        style="width: 100%;"/>
                            </group>
                        </page>
                    </notebook>
                    
                    <field name="company_id" invisible="1"/>
                    <field name="pdf_multiproyecto" invisible="1"/>
                    <field name="pdf_multiproyecto_filename" invisible="1"/>
                    <field name="pdf_proyecciones" invisible="1"/>
                    <field name="pdf_proyecciones_filename" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sicone_informes" model="ir.actions.act_window">
        <field name="name">Informes Ejecutivos</field>
        <field name="res_model">sicone.informes</field>
        <field name="view_mode">form</field>
    </record>
</odoo>
