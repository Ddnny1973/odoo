<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         ACTION
    ================================================================ -->
    <record id="action_sicone_inversion_temporal" model="ir.actions.act_window">
        <field name="name">Inversiones Temporales</field>
        <field name="res_model">sicone.inversion.temporal</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_estado': 'activa'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Sin inversiones registradas</p>
            <p>Registra excedentes de liquidez en CDTs, Fondos o Cuentas Remuneradas.
               El sistema calcula retorno neto después de GMF, retención y comisiones,
               y descuenta automáticamente el monto del excedente disponible.</p>
        </field>
    </record>

    <!-- ================================================================
         VISTA LIST
    ================================================================ -->
    <record id="view_inversion_temporal_list" model="ir.ui.view">
        <field name="name">sicone.inversion.temporal.list</field>
        <field name="model">sicone.inversion.temporal</field>
        <field name="arch" type="xml">
            <list string="Inversiones Temporales"
                  decoration-success="alerta == 'ok' and estado == 'activa'"
                  decoration-info="alerta == 'info'"
                  decoration-warning="alerta == 'advertencia'"
                  decoration-danger="alerta == 'critico'"
                  decoration-muted="estado != 'activa'">

                <field name="nombre"/>
                <field name="instrumento" widget="badge"
                       decoration-primary="instrumento == 'cdt'"
                       decoration-info="instrumento == 'fondo_liquidez'"
                       decoration-warning="instrumento == 'fondo_corto_plazo'"
                       decoration-success="instrumento == 'cuenta_remunerada'"/>
                <field name="entidad"/>
                <field name="monto" sum="Total Invertido"/>
                <field name="tasa_ea" string="Tasa EA %"/>
                <field name="plazo_dias" string="Plazo (d)"/>
                <field name="fecha_inicio"/>
                <field name="fecha_vencimiento"/>
                <field name="dias_restantes" string="Días Rest."
                       decoration-danger="dias_restantes &lt; 7 and estado == 'activa'"
                       decoration-warning="dias_restantes &lt; 30 and estado == 'activa'"/>
                <field name="retorno_neto" sum="Retorno Neto Total"/>
                <field name="roi_neto" string="ROI %"/>
                <field name="tasa_efectiva_neta" string="Tasa Ef. %"/>
                <field name="estado" widget="badge"
                       decoration-success="estado == 'activa'"
                       decoration-muted="estado == 'vencida'"
                       decoration-danger="estado == 'cancelada'"/>
                <field name="alerta" widget="badge"
                       decoration-success="alerta == 'ok'"
                       decoration-info="alerta == 'info'"
                       decoration-warning="alerta == 'advertencia'"
                       decoration-danger="alerta == 'critico'"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         VISTA FORM
    ================================================================ -->
    <record id="view_inversion_temporal_form" model="ir.ui.view">
        <field name="name">sicone.inversion.temporal.form</field>
        <field name="model">sicone.inversion.temporal</field>
        <field name="arch" type="xml">
            <form string="Inversión Temporal">

                <header>
                    <!-- Guardar explícito -->
                    <button special="save" string="💾 Guardar Inversión"
                            class="btn-primary"/>
                    <!-- Acciones de estado -->
                    <button name="action_marcar_vencida" type="object"
                            string="Marcar Vencida" class="btn-secondary"
                            invisible="estado != 'activa'"/>
                    <button name="action_marcar_cancelada" type="object"
                            string="Cancelar Inversión" class="btn-danger"
                            invisible="estado != 'activa'"/>
                    <field name="estado" widget="statusbar"
                           statusbar_visible="activa,vencida,cancelada"/>
                </header>

                <sheet>

                    <!-- ── Alertas de rentabilidad ──────────────────────── -->
                    <div class="alert alert-success mb-3"
                         invisible="alerta != 'ok'">
                        <strong>✅ Inversión rentable.</strong>
                        El retorno neto después de GMF, retención y comisiones es positivo.
                    </div>
                    <div class="alert alert-info mb-3"
                         invisible="alerta != 'info'">
                        <strong>ℹ️ Rentabilidad marginal.</strong>
                        ROI neto inferior al 0.5%. Considera aumentar el plazo o buscar mejor tasa.
                    </div>
                    <div class="alert alert-warning mb-3"
                         invisible="alerta != 'advertencia'">
                        <strong>⚠️ Plazo por debajo del mínimo recomendado (30 días).</strong>
                        Con este plazo, GMF y retención pueden superar los rendimientos.
                    </div>
                    <div class="alert alert-danger mb-3"
                         invisible="alerta != 'critico'">
                        <strong>🔴 Esta inversión genera pérdida.</strong>
                        Los descuentos superan el retorno bruto. Aumenta plazo, tasa o cambia instrumento.
                    </div>

                    <!-- ── Panel de contexto de liquidez ───────────────── -->
                    <div class="o_field_widget o_wrap_field mb-3"
                         style="background:#f8f9fa; border:1px solid #dee2e6;
                                border-radius:6px; padding:12px;">
                        <h6 style="margin:0 0 10px 0; color:#495057;">
                            💰 Contexto de Liquidez Empresa
                        </h6>
                        <group col="4">
                            <field name="excedente_empresa" readonly="1"
                                   string="Excedente Disponible (Dashboard)"
                                   widget="monetary"/>
                            <field name="total_invertido_activo" readonly="1"
                                   string="Ya Invertido (activas)"
                                   widget="monetary"/>
                            <field name="excedente_disponible" readonly="1"
                                   string="Disponible para Invertir"
                                   widget="monetary"
                                   decoration-danger="excedente_disponible &lt; 0"
                                   decoration-warning="excedente_disponible &lt; monto"/>
                            <field name="pct_excedente_usado" readonly="1"
                                   string="% Comprometido"
                                   widget="float"
                                   decoration-warning="pct_excedente_usado &gt; 70"
                                   decoration-danger="pct_excedente_usado &gt; 90"/>
                        </group>
                    </div>

                    <!-- ── Nombre / título ──────────────────────────────── -->
                    <div class="oe_title">
                        <h1>
                            <field name="nombre"
                                   placeholder="Ej: CDT Bancolombia 90d Abr-2026"/>
                        </h1>
                    </div>

                    <!-- ── Identificación + Estado ──────────────────────── -->
                    <group>
                        <group string="Identificación">
                            <field name="instrumento"/>
                            <field name="entidad" placeholder="Bancolombia, Davivienda..."/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Estado">
                            <field name="estado" widget="badge"
                                   decoration-success="estado == 'activa'"
                                   decoration-muted="estado == 'vencida'"
                                   decoration-danger="estado == 'cancelada'"/>
                            <field name="alerta" readonly="1" widget="badge"
                                   decoration-success="alerta == 'ok'"
                                   decoration-info="alerta == 'info'"
                                   decoration-warning="alerta == 'advertencia'"
                                   decoration-danger="alerta == 'critico'"/>
                            <field name="dias_restantes" readonly="1"
                                   invisible="estado != 'activa'"
                                   decoration-danger="dias_restantes &lt; 7"
                                   decoration-warning="dias_restantes &lt; 30"/>
                        </group>
                    </group>

                    <!-- ── Tasas de mercado (Banrep) ────────────────────── -->
                    <group string="📡 Tasas de Referencia del Mercado">
                        <group>
                            <field name="ibr_actual" readonly="1" string="IBR EA (%)"/>
                            <field name="dtf_actual" readonly="1" string="DTF (%)"/>
                            <field name="fecha_tasas" readonly="1"/>
                        </group>
                        <group>
                            <field name="tasa_min_orientativa" readonly="1"
                                   string="Tasa Mín. para este instrumento (%)"/>
                            <field name="tasa_max_orientativa" readonly="1"
                                   string="Tasa Máx. para este instrumento (%)"/>
                            <button name="action_consultar_tasas" type="object"
                                    string="📡 Consultar Tasas Actuales (Banrep)"
                                    class="btn-secondary mt-2"/>
                        </group>
                    </group>

                    <!-- ── Parámetros | Resultados ──────────────────────── -->
                    <group>
                        <group string="📥 Parámetros de la Inversión">
                            <field name="monto"/>
                            <field name="tasa_ea" string="Tasa EA (%)"/>
                            <field name="comision_anual" readonly="1"
                                   string="Comisión Anual (%) — según instrumento"/>
                            <field name="plazo_dias"/>
                            <field name="fecha_inicio"/>
                            <field name="fecha_vencimiento" readonly="1"/>
                        </group>
                        <group string="📊 Resultados Financieros">
                            <field name="retorno_bruto" readonly="1"/>
                            <field name="comision_monto" readonly="1"/>
                            <field name="retencion_fuente" readonly="1"/>
                            <field name="gmf_monto" readonly="1"/>
                            <field name="retorno_neto" readonly="1"
                                   class="fw-bold"
                                   decoration-danger="retorno_neto &lt; 0"/>
                            <field name="capital_final" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Indicadores de rendimiento ───────────────────── -->
                    <group string="📈 Indicadores de Rendimiento">
                        <group>
                            <field name="roi_neto" string="ROI Neto (%)"/>
                            <field name="tasa_efectiva_neta" string="Tasa Efectiva Neta EA (%)"/>
                        </group>
                    </group>

                    <!-- ── Observaciones ─────────────────────────────────── -->
                    <group string="Observaciones">
                        <field name="observaciones" nolabel="1"
                               placeholder="N° de certificado, condiciones especiales, contacto..."/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         SEARCH VIEW
    ================================================================ -->
    <record id="view_inversion_temporal_search" model="ir.ui.view">
        <field name="name">sicone.inversion.temporal.search</field>
        <field name="model">sicone.inversion.temporal</field>
        <field name="arch" type="xml">
            <search string="Buscar Inversiones">
                <field name="nombre"/>
                <field name="entidad"/>
                <field name="instrumento"/>
                <separator/>
                <filter string="Activas" name="activas"
                        domain="[('estado','=','activa')]"/>
                <filter string="Vencidas" name="vencidas"
                        domain="[('estado','=','vencida')]"/>
                <filter string="Canceladas" name="canceladas"
                        domain="[('estado','=','cancelada')]"/>
                <separator/>
                <filter string="CDT" name="cdt"
                        domain="[('instrumento','=','cdt')]"/>
                <filter string="Fondos" name="fondos"
                        domain="[('instrumento','in',['fondo_liquidez','fondo_corto_plazo'])]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Instrumento" name="group_instrumento"
                            context="{'group_by':'instrumento'}"/>
                    <filter string="Entidad" name="group_entidad"
                            context="{'group_by':'entidad'}"/>
                    <filter string="Estado" name="group_estado"
                            context="{'group_by':'estado'}"/>
                    <filter string="Mes de Inicio" name="group_mes"
                            context="{'group_by':'fecha_inicio:month'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
